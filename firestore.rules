rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * OpenMind OS Security Rules
     *
     * CORE PHILOSOPHY:
     * This ruleset enforces a strict User-Ownership model. Every piece of data in the system
     * is explicitly owned by a single user and is organized within that user's private data tree.
     *
     * DATA STRUCTURE:
     * All data is hierarchically nested under /users/{userId}. 
     * Example: /users/{userId}/goals/{goalId}/tasks/{taskId}
     *
     * KEY SECURITY DECISIONS:
     * 1. Authorization Independence: Every document (Goals, Tasks, Nodes, etc.) includes a 
     *    denormalized 'userId' field. Rules verify that this field matches both the 
     *    URL path parameter and the requester's authenticated UID.
     * 2. Prototyping Mode: Rules prioritize authorization (who has access) over strict 
     *    schema validation (what the data looks like). This allows for rapid iteration.
     * 3. Relational Integrity: On document creation, the rules enforce that internal 
     *    foreign keys (like userId or goalId) correctly match the path parameters.
     * 4. Immutable Ownership: Once a document is created, the 'userId' field cannot 
     *    be changed, preventing users from "transferring" or "hijacking" documents.
     */

    // --- Helper Functions ---

    /** @description Checks if the requester is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the user is the owner and the document currently exists. */
    function isExistingOwner(userId) {
      return isOwner(userId) && resource != null;
    }

    /** @description Helper to get incoming data. */
    function incomingData() {
      return request.resource.data;
    }

    // --- Rules ---

    /**
     * @description Rules for the root UserProfile document.
     * @path /users/{userId}
     * @allow Authenticated user (create) where document ID matches their UID.
     * @deny User 'A' (update) User 'B's profile.
     * @principle Self-Creation and Ownership.
     */
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow list: if false; // User profiles are not listable for privacy.
      allow create: if isOwner(userId) && incomingData().id == userId;
      allow update: if isExistingOwner(userId) && incomingData().id == userId;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for personal Goals.
       * @path /users/{userId}/goals/{goalId}
       * @allow Owner (list) all their own goals.
       * @deny Owner (create) a goal with a 'userId' field belonging to someone else.
       * @principle Ownership with path/data consistency.
       */
      match /goals/{goalId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && incomingData().userId == userId && incomingData().id == goalId;
        allow update: if isExistingOwner(userId) && incomingData().userId == userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for Tasks nested under specific Goals.
         * @path /users/{userId}/goals/{goalId}/tasks/{taskId}
         * @allow Owner (create) a task where goalId matches the path.
         * @deny Owner (update) a task to change its 'userId' or 'goalId' (immutable keys).
         * @principle Deep hierarchical ownership and relationship validation.
         */
        match /tasks/{taskId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && incomingData().userId == userId && incomingData().goalId == goalId && incomingData().id == taskId;
          allow update: if isExistingOwner(userId) && incomingData().userId == userId && incomingData().goalId == resource.data.goalId;
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Rules for User-defined Tags.
       * @path /users/{userId}/tags/{tagId}
       * @allow Owner (get) a specific tag.
       * @deny Unauthenticated users (list).
       * @principle Simple ownership model for metadata.
       */
      match /tags/{tagId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && incomingData().userId == userId && incomingData().id == tagId;
        allow update: if isExistingOwner(userId) && incomingData().userId == userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Knowledge Graph Nodes.
       * @path /users/{userId}/knowledgeNodes/{nodeId}
       * @allow Owner (create) a node with a title and content.
       * @deny Any user (delete) a node they don't own.
       * @principle Privacy of personal knowledge base.
       */
      match /knowledgeNodes/{nodeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && incomingData().userId == userId && incomingData().id == nodeId;
        allow update: if isExistingOwner(userId) && incomingData().userId == userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for Knowledge Graph Edges (relationships).
       * @path /users/{userId}/knowledgeEdges/{edgeId}
       * @allow Owner (create) a relationship between two of their own nodes.
       * @deny User (create) an edge pointing to another user's node (implicit via path).
       * @principle Relational integrity for user-owned graph data.
       */
      match /knowledgeEdges/{edgeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && incomingData().userId == userId && incomingData().id == edgeId;
        allow update: if isExistingOwner(userId) && incomingData().userId == userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for productivity metrics.
       * @path /users/{userId}/analyticsMetrics/{metricId}
       * @allow Owner (list) metrics to render charts.
       * @deny Owner (update) 'userId' to move a metric to another account.
       * @principle Ownership and field immutability.
       */
      match /analyticsMetrics/{metricId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && incomingData().userId == userId && incomingData().id == metricId;
        allow update: if isExistingOwner(userId) && incomingData().userId == userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for AI-generated Learning Roadmaps.
       * @path /users/{userId}/learningRoadmaps/{roadmapId}
       * @allow Owner (get) their generated roadmap.
       * @deny Any write (create/update/delete) that doesn't include the correct userId.
       * @principle Securing AI-generated output for the specific user.
       */
      match /learningRoadmaps/{roadmapId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && incomingData().userId == userId && incomingData().id == roadmapId;
        allow update: if isExistingOwner(userId) && incomingData().userId == userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for steps within a Roadmap.
         * @path /users/{userId}/learningRoadmaps/{roadmapId}/roadmapSteps/{stepId}
         * @allow Owner (update) the status of a specific step (e.g., 'Completed').
         * @deny Owner (create) a step where learningRoadmapId doesn't match the path.
         * @principle Deeply nested relational consistency.
         */
        match /roadmapSteps/{stepId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && incomingData().learningRoadmapId == roadmapId && incomingData().id == stepId;
          allow update: if isExistingOwner(userId) && incomingData().learningRoadmapId == resource.data.learningRoadmapId;
          allow delete: if isExistingOwner(userId);
        }
      }
    }
  }
}