rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE PHILOSOPHY
     * This ruleset enforces a strict user-ownership model for the OpenMind OS application. 
     * It leverages a hierarchical data structure where all personal data is nested under 
     * the specific user's document path (/users/{userId}).
     *
     * DATA STRUCTURE
     * - /users/{userId}: The root of a user's private data tree.
     * - /users/{userId}/[subcollections]: Contains goals, tasks, tags, knowledge, and metrics.
     * - /skills/{skillId}: A top-level, public read-only collection for global skill definitions.
     *
     * KEY SECURITY DECISIONS
     * 1. Authorization Independence: Every user-owned document includes a 'userId' field.
     *    Rules verify that this field matches both the URL path and the authenticated user's UID.
     * 2. Prototyping Mode: Rules prioritize strict authorization (who can access) while 
     *    remaining flexible on the internal data shape of content fields to allow rapid iteration.
     * 3. Immutability: Critical relational fields (like userId) are made immutable after 
     *    creation to prevent data being moved between user accounts.
     * 4. Structural Segregation: Private data is isolated by path, ensuring that a simple 
     *    list operation on a subcollection naturally filters to only the user's data.
     *
     * DENORMALIZATION FOR AUTHORIZATION
     * To maximize performance and minimize cost, the 'userId' is denormalized into every 
     * subcollection document (e.g., Tasks, RoadmapSteps). This allows rules to verify 
     * ownership instantly without calling get() on parent Goal or Roadmap documents.
     */

    // --- HELPER FUNCTIONS ---

    /** @description Checks if the request is from an authenticated user. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** @description Checks if the authenticated user matches the provided userId from the path. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** @description Checks if the document exists and the authenticated user is the owner. */
    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- COLLECTION RULES ---

    /**
     * @description Rules for the primary User Profile.
     * @path /users/{userId}
     * @allow Authenticated user (create) where request.auth.uid == userId.
     * @deny User 'A' (update) User 'B's profile.
     * @principle Self-creation and strict ownership for user roots.
     */
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId);

      /**
       * @description Rules for personal goals.
       * @path /users/{userId}/goals/{goalId}
       * @allow Owner (list) their own goals.
       * @deny Non-owner (get) a goal.
       * @principle Path-based ownership with relational integrity validation.
       */
      match /goals/{goalId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for tasks within goals.
         * @path /users/{userId}/goals/{goalId}/tasks/{taskId}
         * @allow Owner (create) a task ensuring userId and goalId match the path.
         * @deny Owner (update) and attempt to change the goalId or userId.
         * @principle Denormalized ownership and cross-link validation.
         */
        match /tasks/{taskId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.userId == userId && request.resource.data.goalId == goalId;
          allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId && request.resource.data.goalId == resource.data.goalId;
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Rules for user-defined tags.
       * @path /users/{userId}/tags/{tagId}
       * @allow Owner (create) a tag with their userId.
       * @deny Non-owner (list) tags.
       * @principle Path-based ownership.
       */
      match /tags/{tagId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for knowledge graph nodes.
       * @path /users/{userId}/knowledgeNodes/{nodeId}
       * @allow Owner (get) their own knowledge node.
       * @deny Non-owner (create) a node in this path.
       * @principle Path-based ownership.
       */
      match /knowledgeNodes/{nodeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for knowledge graph edges.
       * @path /users/{userId}/knowledgeEdges/{edgeId}
       * @allow Owner (list) their knowledge edges.
       * @deny Owner (update) changing the owner userId.
       * @principle Path-based ownership and relational immutability.
       */
      match /knowledgeEdges/{edgeId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for user-specific skill tracking.
       * @path /users/{userId}/userSkills/{userSkillId}
       * @allow Owner (create) a skill proficiency record.
       * @deny Unauthenticated user (get).
       * @principle Path-based ownership.
       */
      match /userSkills/{userSkillId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);
      }

      /**
       * @description Rules for personal learning roadmaps.
       * @path /users/{userId}/learningRoadmaps/{roadmapId}
       * @allow Owner (get) their generated roadmap.
       * @deny Non-owner (delete) a roadmap.
       * @principle Path-based ownership.
       */
      match /learningRoadmaps/{roadmapId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if isExistingOwner(userId) && request.resource.data.userId == resource.data.userId;
        allow delete: if isExistingOwner(userId);

        /**
         * @description Rules for individual steps in a roadmap.
         * @path /users/{userId}/learningRoadmaps/{roadmapId}/roadmapSteps/{stepId}
         * @allow Owner (create) a step linked to the correct roadmapId.
         * @deny Non-owner (list) roadmap steps.
         * @principle Denormalized ownership and path consistency.
         */
        match /roadmapSteps/{stepId} {
          allow get, list: if isOwner(userId);
          allow create: if isOwner(userId) && request.resource.data.roadmapId == roadmapId;
          allow update: if isExistingOwner(userId) && request.resource.data.roadmapId == resource.data.roadmapId;
          allow delete: if isExistingOwner(userId);
        }
      }

      /**
       * @description Rules for performance and cognitive metric snapshots.
       * @path /users/{userId}/metricSnapshots/{snapshotId}
       * @allow Owner (list) their historical snapshots.
       * @deny Owner (update) because snapshots are typically historical/immutable records.
       * @principle Path-based ownership; update is explicitly denied for data integrity.
       */
      match /metricSnapshots/{snapshotId} {
        allow get, list: if isOwner(userId);
        allow create: if isOwner(userId) && request.resource.data.userId == userId;
        allow update: if false;
        allow delete: if isExistingOwner(userId);
      }
    }

    /**
     * @description Rules for the global library of skill definitions.
     * @path /skills/{skillId}
     * @allow Any authenticated user (get, list) to reference skills.
     * @deny Any user (create, update, delete). These are managed by system admins.
     * @principle Public read with restricted writes.
     */
    match /skills/{skillId} {
      allow get, list: if isSignedIn();
      allow create, update, delete: if false; // TODO: Implement admin-only writes when admin roles are defined.
    }
  }
}